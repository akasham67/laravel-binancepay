{
  "name": "codeglen/laravel-binancepay",
  "description": "A Laravel package for integrating Binance Pay API.",
  "keywords": [
    "codeglen",
    "laravel",
    "binancepay",
    "binance",
    "payment",
    "api"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Abul Kashem",
      "email": "akasham67@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "phpunit/phpunit": "^10.5|^11.5"
  },
  "autoload": {
    "psr-4": {
      "Codeglen\\BinancePay\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Codeglen\\BinancePay\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Codeglen\\BinancePay\\BinancePayServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
